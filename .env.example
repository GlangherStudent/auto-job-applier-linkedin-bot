##############################################
# Environment template for Auto Job Applier #
##############################################

# LinkedIn credentials
# IMPORTANT:
# - Copy this file to .env
# - Fill in your real credentials locally
# - NEVER commit the .env file to Git

LINKEDIN_USERNAME=your_email@example.com
LINKEDIN_PASSWORD=your_password_here


# LLM provider API keys
# Only set the providers you actually use.

GROQ_API_KEY=YOUR_GROQ_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
HF_API_KEY=YOUR_HUGGINGFACE_API_KEY

LLMGATEWAY_API_KEY_1=YOUR_LLM_API_KEY_1
LLMGATEWAY_API_KEY_2=YOUR_LLM_API_KEY_2
LLMGATEWAY_API_KEY_3=YOUR_LLM_API_KEY_3


# Flask UI settings (optional)
# APP_DEBUG controls Flask debug mode (never enable in production).
# APP_PORT sets the port for the web UI (default 5000).

APP_DEBUG=false
APP_PORT=5000


# Instructions:
# 1. Copy this file: cp .env.example .env   (Windows: copy .env.example .env)
# 2. Edit .env with your REAL credentials and API keys
# 3. NEVER commit .env to Git
# 4. Rotate your LinkedIn password and API keys if you ever suspect they were exposed

